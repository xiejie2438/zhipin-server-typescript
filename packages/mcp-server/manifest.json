{
  "dxt_version": "0.2",
  "name": "zhipin-server-mcp",
  "version": "0.1.1",
  "description": "The official MCP Server for the Zhipin Server API",
  "author": {
    "name": "Zhipin Server",
    "email": "tech@zhipin.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiejie2438/zhipin-server-typescript.git"
  },
  "homepage": "https://github.com/xiejie2438/zhipin-server-typescript/tree/main/packages/mcp-server#readme",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "ZHIPIN_SERVER_API_KEY": "${user_config.ZHIPIN_SERVER_API_KEY}"
      }
    }
  },
  "user_config": {
    "ZHIPIN_SERVER_API_KEY": {
      "title": "api_key",
      "description": "",
      "required": false,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": [
    "api"
  ]
}
